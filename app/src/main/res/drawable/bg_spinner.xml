<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Fond blanc -->
    <solid android:color="@android:color/white" />

    <!-- Bordure grise -->
    <stroke
        android:width="1dp"
        android:color="#DDDDDD" />

    <!-- Coins arrondis -->
    <corners android:radius="4dp" />

    <!-- Padding intérieur -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
</shape>